<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CreateInputRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">14dp</item>
    </style>

    <style name="CreateMultilineInputRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">112dp</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:gravity">top</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">14dp</item>
    </style>

    <style name="CreateInputIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
    </style>

    <style name="CreateInputEditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:inputType">text</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/black_text</item>
        <item name="android:textColorHint">@color/gray_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CreateMultilineEditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:gravity">top</item>
        <item name="android:inputType">textMultiLine</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:textColor">@color/black_text</item>
        <item name="android:textColorHint">@color/gray_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CreateValueText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/gray_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CreateFieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/gray_text</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="CreateDropdownText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textColor">@color/black_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CreateQuickText">
        <item name="android:layout_width">96dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/black_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
