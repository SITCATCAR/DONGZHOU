<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_activity"
    tools:context=".Activities.CreateActivities.FormCreateActivity">

    <LinearLayout
        android:id="@+id/layoutNavBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:srcCompat="@mipmap/ic_results_page_return" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:textColor="@color/black_text"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Website" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/btnCreate"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutNavBar">

        <LinearLayout
            android:id="@+id/layoutForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="30dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/layoutUrl"
                style="@style/CreateInputRow"
                android:visibility="gone"
                tools:visibility="visible">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_url_unselected" />

                <EditText
                    android:id="@+id/etUrl"
                    style="@style/CreateInputEditText"
                    android:hint="Enter URL" />

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    android:layout_marginEnd="0dp"
                    app:srcCompat="@mipmap/ic_delete" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutQuickText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvPrefixWww"
                    style="@style/CreateQuickText"
                    android:text="www." />

                <TextView
                    android:id="@+id/tvSuffixCom"
                    style="@style/CreateQuickText"
                    android:layout_marginStart="10dp"
                    android:text=".com" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutWifiName"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_wifi_unselected" />

                <EditText
                    android:id="@+id/etWifiName"
                    style="@style/CreateInputEditText"
                    android:hint="Network name" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSecurity"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_type" />

                <TextView
                    android:id="@+id/tvSecurity"
                    style="@style/CreateValueText"
                    android:text="WPA/WPA2" />

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    android:layout_marginEnd="0dp"
                    app:srcCompat="@mipmap/ic_down" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSecurityDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="38dp"
                android:paddingTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSecurityWpa"
                    style="@style/CreateDropdownText"
                    android:text="WPA/WPA2" />

                <TextView
                    android:id="@+id/tvSecurityWep"
                    style="@style/CreateDropdownText"
                    android:text="WEP" />

                <TextView
                    android:id="@+id/tvSecurityNone"
                    style="@style/CreateDropdownText"
                    android:text="None" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPassword"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_password" />

                <EditText
                    android:id="@+id/etPassword"
                    style="@style/CreateInputEditText"
                    android:hint="Password" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutText"
                style="@style/CreateMultilineInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etText"
                    style="@style/CreateMultilineEditText"
                    android:hint="Enter text" />

                <TextView
                    android:id="@+id/tvTextCount"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="bottom"
                    android:paddingBottom="10dp"
                    android:text="0"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutName"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_name" />

                <EditText
                    android:id="@+id/etName"
                    style="@style/CreateInputEditText"
                    android:hint="Name" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPhone1"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_phone" />

                <EditText
                    android:id="@+id/etPhone1"
                    style="@style/CreateInputEditText"
                    android:hint="Phone number" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPhone2"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_phone" />

                <EditText
                    android:id="@+id/etPhone2"
                    style="@style/CreateInputEditText"
                    android:hint="Second phone number" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPhone"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_phone" />

                <EditText
                    android:id="@+id/etPhone"
                    style="@style/CreateInputEditText"
                    android:hint="Phone number" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEmail"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_email_unselected" />

                <EditText
                    android:id="@+id/etEmail"
                    style="@style/CreateInputEditText"
                    android:hint="E-mail" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvSubjectLabel"
                style="@style/CreateFieldLabel"
                android:text="Subject"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutSubject"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etSubject"
                    style="@style/CreateInputEditText"
                    android:hint="Subject" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvContentLabel"
                style="@style/CreateFieldLabel"
                android:text="Content"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutContent"
                style="@style/CreateMultilineInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etContent"
                    style="@style/CreateMultilineEditText"
                    android:hint="Content" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvMessageLabel"
                style="@style/CreateFieldLabel"
                android:text="Message"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutMessage"
                style="@style/CreateMultilineInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etMessage"
                    style="@style/CreateMultilineEditText"
                    android:hint="Message content" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvTitleLabel"
                style="@style/CreateFieldLabel"
                android:text="Title"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutTitle"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etTitle"
                    style="@style/CreateInputEditText"
                    android:hint="Title" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvLocationLabel"
                style="@style/CreateFieldLabel"
                android:text="Location"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutLocation"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etLocation"
                    style="@style/CreateInputEditText"
                    android:hint="Location" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAllDay"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <TextView
                    style="@style/CreateValueText"
                    android:text="All day" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAllDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutStartTime"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <TextView
                    style="@style/CreateValueText"
                    android:text="Start" />

                <TextView
                    android:id="@+id/tvStartTime"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="Jan 8 9:30"
                    android:textColor="@color/gray_text"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEndTime"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <TextView
                    style="@style/CreateValueText"
                    android:text="End" />

                <TextView
                    android:id="@+id/tvEndTime"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="11:30"
                    android:textColor="@color/gray_text"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDescriptionLabel"
                style="@style/CreateFieldLabel"
                android:text="Description"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutDescription"
                style="@style/CreateMultilineInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etDescription"
                    style="@style/CreateMultilineEditText"
                    android:hint="Description" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAddress"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_address" />

                <EditText
                    android:id="@+id/etAddress"
                    style="@style/CreateInputEditText"
                    android:hint="Address" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutBirthday"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_birthday" />

                <TextView
                    style="@style/CreateValueText"
                    android:text="Birthday" />

                <TextView
                    android:id="@+id/tvBirthday"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="Jan 8"
                    android:textColor="@color/gray_text"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutOrg"
                style="@style/CreateInputRow"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    style="@style/CreateInputIcon"
                    app:srcCompat="@mipmap/ic_create_org" />

                <EditText
                    android:id="@+id/etOrg"
                    style="@style/CreateInputEditText"
                    android:hint="Organization" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvNoteLabel"
                style="@style/CreateFieldLabel"
                android:text="Note"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutNote"
                style="@style/CreateMultilineInputRow"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etNote"
                    style="@style/CreateMultilineEditText"
                    android:hint="Note" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCreate"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_button_unable"
        android:text="@string/ca_create"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
