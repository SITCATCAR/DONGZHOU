<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_activity"
    tools:context=".Activities.CreateActivities.EmailCreateActivity">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutStatusPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/viewStatusLeft"
                android:layout_width="20dp"
                android:layout_height="8dp"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tvMockTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:30"
                android:textColor="#222222"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 对应 HTML: nav-bar_1 -->
        <LinearLayout
            android:id="@+id/layoutNavBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                app:srcCompat="@mipmap/ic_results_page_return" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="E-mail"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- 对应 HTML: group_2 / section_3 表单区域 -->
    <LinearLayout
        android:id="@+id/layoutForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <!-- 对应 HTML: input_1 / group_2，E-mail 输入行 -->
        <LinearLayout
            android:id="@+id/layoutEmailInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="14dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivEmailIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:srcCompat="@mipmap/ic_email_unselected" />


            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_marginStart="12dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="E-mail"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:textColor="#222222"
                android:textColorHint="#999999"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivExpandEmail"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="12dp"
                app:srcCompat="@mipmap/ic_down" />

        </LinearLayout>

        <!-- 展开后的额外内容：Subject + Content -->
        <LinearLayout
            android:id="@+id/layoutExtraEmailContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- 对应 HTML: text_4 Subject -->
            <TextView
                android:id="@+id/tvSubjectLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:text="Subject"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- 对应 HTML: input_2 -->
            <LinearLayout
                android:id="@+id/layoutSubjectInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="14dp">

                <EditText
                    android:id="@+id/etSubject"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Please enter something"
                    android:inputType="text"
                    android:singleLine="true"
                    android:textColor="#222222"
                    android:textColorHint="#999999"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- 对应 HTML: text_6 Content -->
            <TextView
                android:id="@+id/tvContentLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:text="Content"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- 对应 HTML: text-wrapper_1 -->
            <LinearLayout
                android:id="@+id/layoutContentInput"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="14dp">

                <EditText
                    android:id="@+id/etContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="Please enter something"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:overScrollMode="never"
                    android:padding="0dp"
                    android:scrollbars="none"
                    android:textColor="#222222"
                    android:textColorHint="#999999"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 对应 HTML: button_1 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCreate"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_marginTop="236dp"
        android:background="@drawable/bg_create_button"
        android:text="@string/ca_create"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutForm" />

</androidx.constraintlayout.widget.ConstraintLayout>