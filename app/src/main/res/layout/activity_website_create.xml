<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_activity"
    tools:context=".Activities.CreateActivities.WebsiteCreateActivity">

    <LinearLayout
        android:id="@+id/layoutNavBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            app:srcCompat="@mipmap/ic_results_page_return"
            android:textColor="#222222"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/website"
            android:textColor="@color/black_text"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutNavBar">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            app:srcCompat="@mipmap/ic_url_unselected"/>

        <EditText
            android:id="@+id/etFacebookId"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/website_input_hint"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="#222222"
            android:textColorHint="#999999"
            android:textSize="14sp" />
        
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="10dp"
            android:src="@mipmap/ic_delete"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/layoutInput"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:gravity="center"
            android:layout_width="96dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_input"
            android:layout_marginStart="16dp"
            android:text="www."
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/black_text"/>

        <TextView
            android:gravity="center"
            android:layout_width="96dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_input"
            android:text=".com"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            android:textColor="@color/black_text"/>
        
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>