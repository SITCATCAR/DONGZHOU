<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <androidx.camera.view.PreviewView
        android:id="@+id/preView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/scanBox"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.65"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.3" >

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="15.11dp"
            android:layout_height="15.11dp"
            app:srcCompat="@drawable/scan_frame_tl"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="15.11dp"
            android:layout_height="15.11dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:src="@drawable/scan_frame_tr"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="15.11dp"
            android:layout_height="15.11dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/scan_frame_bl"/>

        <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="15.11dp"
        android:layout_height="15.11dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/scan_frame_br"/>

        <com.swx.dongzhou.pages.scanPage.ScanView
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/maskTop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/scan_mask"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/scanBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/maskBottom"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/scan_mask"
        app:layout_constraintTop_toBottomOf="@id/scanBox"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/maskLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/scan_mask"
        app:layout_constraintTop_toTopOf="@id/scanBox"
        app:layout_constraintBottom_toBottomOf="@id/scanBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/scanBox" />

    <View
        android:id="@+id/maskRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/scan_mask"
        app:layout_constraintTop_toTopOf="@id/scanBox"
        app:layout_constraintBottom_toBottomOf="@id/scanBox"
        app:layout_constraintStart_toEndOf="@id/scanBox"
        app:layout_constraintEnd_toEndOf="parent" />




    <TextView
        android:id="@+id/tvScanHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="@color/scan_hint_text"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/scanBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ImageButton
        android:id="@+id/btnZoomReduce"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="20dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/scan_zoom_reduce"
        android:scaleType="centerInside"
        android:src="@mipmap/ic_scan_reduce"
        app:layout_constraintTop_toBottomOf="@id/tvScanHint"
        app:layout_constraintStart_toStartOf="parent" />

    <SeekBar
        android:id="@+id/zoomSeekBar"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginHorizontal="12dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/scan_blue"
        android:thumbTint="@color/scan_blue"
        app:layout_constraintBottom_toBottomOf="@id/btnZoomReduce"
        app:layout_constraintEnd_toStartOf="@id/btnZoomAdd"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@id/btnZoomReduce"
        app:layout_constraintTop_toTopOf="@id/btnZoomReduce"
        app:layout_constraintVertical_bias="0.0" />

    <ImageButton
        android:id="@+id/btnZoomAdd"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/scan_zoom_add"
        android:scaleType="centerInside"
        android:src="@mipmap/ic_scan_add"
        app:layout_constraintTop_toTopOf="@id/btnZoomReduce"
        app:layout_constraintBottom_toBottomOf="@id/btnZoomReduce"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:background="@drawable/scan_icon_bg"
        android:layout_marginTop="27dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btnZoomReduce"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnGallery"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="centerInside"
                android:src="@mipmap/ic_scan_gallery" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gallery"
                android:textColor="@color/white"
                android:textSize="10sp"/>

        </LinearLayout>



        <Space
            android:layout_width="28dp"
            android:layout_height="50dp" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnFlash"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="centerInside"
                android:src="@mipmap/ic_scan_lighting" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flashing"
                android:textColor="@color/white"
                android:textSize="10sp"/>

        </LinearLayout>


        <Space
            android:layout_width="28dp"
            android:layout_height="50dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnBatch"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="centerInside"
                android:src="@mipmap/ic_scan_batch" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Batch"
                android:textColor="@color/white"
                android:textSize="10sp"/>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
