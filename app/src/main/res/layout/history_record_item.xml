<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_history_record"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/image_record_icon"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:scaleType="centerInside"
        android:src="@mipmap/ic_url" />

    <LinearLayout
        android:id="@+id/layout_record_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_record_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="https://fonts.google.comlec.c..."
            android:textColor="@color/black_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_record_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="URL"
            android:textColor="@color/gray_text"
            android:textSize="12sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/text_record_time"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="16:28"
        android:textColor="@color/history_time_text"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/image_record_favorite"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginStart="10dp"
        android:src="@mipmap/ic_favorites_selected" />

</LinearLayout>
