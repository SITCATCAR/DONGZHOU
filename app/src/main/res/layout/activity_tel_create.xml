<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_activity"
    tools:context=".Activities.CreateActivities.TelCreateActivity">

    <!-- 对应 HTML: section_1 / 顶部导航整体 -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 对应 HTML: block_2 状态栏占位 -->
        <LinearLayout
            android:id="@+id/layoutStatusPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 对应 HTML: group_1，占位 -->
            <View
                android:id="@+id/viewStatusLeft"
                android:layout_width="20dp"
                android:layout_height="8dp"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tvMockTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:text="12:30"
                android:textColor="#222222"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 对应 HTML: nav-bar_1 -->
        <LinearLayout
            android:id="@+id/layoutNavBarWrapper"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="vertical">

            <!-- 对应 HTML: section_2 -->
            <LinearLayout
                android:id="@+id/layoutNavBar"
                android:layout_width="match_parent"
                android:layout_height="47dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- 对应 HTML: icon_1，返回图标 -->
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:gravity="center"
                    app:srcCompat="@mipmap/ic_results_page_return" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Tel"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 对应 HTML: section_3，底部分隔/占位 -->
            <View
                android:id="@+id/viewNavBottomPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </LinearLayout>

    <!-- 对应 HTML: input_1 -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivPhoneIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:srcCompat="@mipmap/ic_create_phone" />


        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="0dp"
            android:layout_marginStart="12dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Phone number"
            android:inputType="phone"
            android:singleLine="true"
            android:textColor="#222222"
            android:textColorHint="#999999"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- 对应 HTML: button_1 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCreate"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_marginTop="236dp"
        android:background="@drawable/bg_create_button"
        android:text="@string/ca_create"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutInput" />

</androidx.constraintlayout.widget.ConstraintLayout>