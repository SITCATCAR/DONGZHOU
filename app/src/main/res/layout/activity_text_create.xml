<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_create_activity"
    tools:context=".Activities.CreateActivities.TextCreateActivity">

    <LinearLayout
        android:id="@+id/layoutNavBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            app:srcCompat="@mipmap/ic_results_page_return" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Text"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutNavBar">

        <!-- 大文本输入框 -->
        <LinearLayout
            android:id="@+id/layoutTextInputCard"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_input"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="16dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/layoutInputTop"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <!-- HTML 中 box_6，占位输入图标，暂不指定 src -->
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivTextIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    tools:background="#DDDDDD" />

                <EditText
                    android:id="@+id/etTextContent"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="Please enter something"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:overScrollMode="never"
                    android:padding="0dp"
                    android:scrollbars="none"
                    android:textColor="#222222"
                    android:textColorHint="#999999"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvTextCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0"
                android:textColor="#999999"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- 示例说明区域 -->
        <LinearLayout
            android:id="@+id/layoutExample"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="22dp"
            android:layout_marginEnd="16dp"
            android:gravity="top"
            android:orientation="horizontal">

            <!-- HTML 中 icon_2，占位图标，暂不指定 src -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivExampleIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                tools:background="#DDDDDD" />

            <TextView
                android:id="@+id/tvExampleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:lineSpacingExtra="3dp"
                android:text="a spoken or written representation or account of a person, object, or event or even a spoken or written representation or…"
                android:textColor="#999999"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCreate"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_marginTop="236dp"
        android:background="@drawable/bg_create_button"
        android:text="@string/ca_create"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutContent" />

</androidx.constraintlayout.widget.ConstraintLayout>